# ---------- Qdrant ----------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=nfcorpus

# ---------- Models ----------
# One of: BAAI/bge-small-en-v1.5 (384), BAAI/bge-base-en-v1.5 (768), BAAI/bge-large-en-v1.5 (1024)
DENSE_MODEL=BAAI/bge-small-en-v1.5
SPARSE_MODEL=Qdrant/bm25
# One of: BAAI/bge-reranker-base, BAAI/bge-reranker-large
RERANKER_MODEL=BAAI/bge-reranker-base

# ---------- Chunking ----------
# One of: recursive | fixed | semantic
CHUNK_STRATEGY=recursive
CHUNK_SIZE=512
CHUNK_OVERLAP=50
# Only used by semantic strategy
SEMANTIC_BREAKPOINT_TYPE=percentile
SEMANTIC_BREAKPOINT_AMOUNT=95

# ---------- Retrieval defaults ----------
TOP_K=5
RERANK_TOP_N=20
PREFETCH_LIMIT=50
# Weighted RRF weights (dense, sparse). k is the RRF constant.
WEIGHT_DENSE=1.0
WEIGHT_SPARSE=1.0
RRF_K=60
USE_RERANKER=true

# ---------- Ingestion ----------
MANIFEST_PATH=./data/manifest.db
BATCH_SIZE=64
# Max documents to load from NFCorpus corpus (-1 for all ~3.6k)
MAX_DOCS=-1

# ---------- API ----------
API_HOST=0.0.0.0
API_PORT=8000
